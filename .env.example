# Injetado automaticamente pelo Vercel quando você cria/conecta um banco
# Postgres em Project > Storage. Para rodar localmente com `vercel dev`,
# rode `vercel env pull` para baixar os valores reais.
POSTGRES_URL=

# Segredo usado para assinar o cookie de sessão (JWT). Gere um valor forte,
# por exemplo: openssl rand -base64 48
# Configure em Project Settings > Environment Variables no Vercel.
JWT_SECRET=
